<odoo>

    <record id="action_pos_daily_report_pdf" model="ir.actions.report">
        <field name="name">Ventas POS Día</field>
        <field name="model">lms.pos.daily.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lms_financial_reports.pos_daily_report_pdf_template</field>
        <field name="report_file">lms_financial_reports.pos_daily_report_pdf_template</field>
    </record>

    <template id="pos_daily_report_pdf_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <t t-set="data" t-value="o._get_report_data()"/>
                <t t-set="company" t-value="o.env.company"/>

                <div class="page">
                    <h2 style="text-align:center;">REPORTE VENTAS POS DÍA</h2>

                    <p style="text-align:center;">
                        <strong><span t-esc="company.name"/></strong><br/>
                        Fecha: <span t-esc="o.date"/>
                        <t t-if="o.pos_config_id">
                            <br/>Punto de Venta: <span t-esc="o.pos_config_id.display_name"/>
                        </t>
                    </p>

                    <br/>

                    <table class="table table-sm table-bordered" style="font-size:8px;">
                        <thead style="background-color:#f2f2f2;">
                            <tr>
                                <th>Fecha</th>
                                <th>Sesión</th>
                                <th>Cajero</th>
                                <th style="text-align:right;">Órdenes</th>
                                <th style="text-align:right;">Rec. CxC</th>
                                <th style="text-align:right;">Efectivo POS</th>
                                <th style="text-align:right;">Efectivo CxC</th>
                                <th style="text-align:right;">Total Efectivo</th>
                                <th style="text-align:right;">Contado</th>
                                <th style="text-align:right;">Dif.</th>
                                <th style="text-align:right;">Tarjeta POS</th>
                                <th style="text-align:right;">Tarjeta CxC</th>
                                <th style="text-align:right;">Total Tarjeta</th>
                                <th style="text-align:right;">Transf. POS</th>
                                <th style="text-align:right;">Transf. CxC</th>
                                <th style="text-align:right;">Total Transf.</th>
                                <th style="text-align:right;">Total Recibido</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data['pos_groups']" t-as="group">
                                <tr style="font-weight:bold; background-color:#eaeaea;">
                                    <td colspan="17">
                                        <span t-esc="group['pos_name']"/>
                                    </td>
                                </tr>

                                <t t-foreach="group['sessions']" t-as="line">
                                    <tr>
                                        <td><span t-esc="line['date']"/></td>
                                        <td><span t-esc="line['session_name']"/></td>
                                        <td><span t-esc="line['cashier_name']"/></td>
                                        <td style="text-align:right;"><span t-esc="line['order_count']"/></td>
                                        <td style="text-align:right;"><span t-esc="line['cxc_receipt_count']"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['cash_amount'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['cxc_cash_amount'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['total_cash_collected'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['cash_counted'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['cash_difference'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['card_amount'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['cxc_card_amount'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['total_card_collected'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['transfer_amount'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['cxc_transfer_amount'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['total_transfer_collected'])"/></td>
                                        <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(line['total_sales'])"/></td>
                                    </tr>
                                </t>

                                <t t-set="subtotal" t-value="group['subtotal']"/>
                                <tr style="font-weight:bold; background-color:#f5f5f5;">
                                    <td colspan="3">SUBTOTAL <span t-esc="group['pos_name']"/></td>
                                    <td style="text-align:right;"><span t-esc="subtotal['order_count']"/></td>
                                    <td style="text-align:right;"><span t-esc="subtotal['cxc_receipt_count']"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['cash_amount'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['cxc_cash_amount'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['total_cash_collected'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['cash_counted'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['cash_difference'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['card_amount'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['cxc_card_amount'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['total_card_collected'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['transfer_amount'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['cxc_transfer_amount'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['total_transfer_collected'])"/></td>
                                    <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(subtotal['total_sales'])"/></td>
                                </tr>
                            </t>

                            <t t-set="totals" t-value="data['totals']"/>
                            <tr style="font-weight:bold; background-color:#d9d9d9;">
                                <td colspan="3">TOTAL RECIBIDO POS DÍA</td>
                                <td style="text-align:right;"><span t-esc="totals['order_count']"/></td>
                                <td style="text-align:right;"><span t-esc="totals['cxc_receipt_count']"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['cash_amount'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['cxc_cash_amount'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['total_cash_collected'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['cash_counted'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['cash_difference'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['card_amount'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['cxc_card_amount'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['total_card_collected'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['transfer_amount'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['cxc_transfer_amount'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['total_transfer_collected'])"/></td>
                                <td style="text-align:right;"><span t-esc="'{:,.2f}'.format(totals['total_sales'])"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
