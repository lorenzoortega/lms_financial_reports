<odoo>

    <record id="view_aging_payable_summary_line_list" model="ir.ui.view">
        <field name="name">aging.payable.summary.line.list</field>
        <field name="model">lms.aging.payable.summary.line</field>
        <field name="arch" type="xml">
            <list string="Balance por Antigüedad Resumido (Proveedores)" create="false" delete="false">

                <field name="sequence" column_invisible="1"/>
                <field name="is_total" column_invisible="1"/>

                <field name="vendor_name"/>
                <field name="balance_pending"/>
                <field name="not_due"/>
                <field name="bucket_1_30"/>
                <field name="bucket_31_60"/>
                <field name="bucket_61_90"/>
                <field name="bucket_90_plus"/>

                <button name="action_view_invoices"
                        type="object"
                        string="Ver facturas"
                        invisible="is_total"/>

            </list>
        </field>
    </record>

    <record id="view_account_move_payable_drilldown_list" model="ir.ui.view">
        <field name="name">account.move.payable.drilldown.list</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <list string="Facturas Proveedor" create="false" delete="false" edit="false">
                <field name="currency_id" column_invisible="1"/>
                <field name="name" string="Número"/>
                <field name="partner_id" string="Proveedor"/>
                <field name="ref" string="NCF / Referencia"/>
                <field name="invoice_date_due" string="Fecha de vencimiento"/>
                <field name="amount_untaxed" string="Impuestos no inc." sum="Total"/>
                <field name="amount_total" string="Total factura" sum="Total"/>
                <field name="amount_residual" string="Cantidad por pagar" sum="Total"/>
                <field name="payment_state" string="Estado"/>
            </list>
        </field>
    </record>

</odoo>