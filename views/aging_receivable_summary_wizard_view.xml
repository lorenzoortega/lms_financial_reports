<odoo>

    <record id="view_aging_receivable_summary_wizard_form" model="ir.ui.view">
        <field name="name">lms.aging.receivable.summary.wizard.form</field>
        <field name="model">lms.aging.receivable.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Balance por Antigüedad Resumido">
                <group>
                    <group>
                        <field name="date_to" string="Fecha de corte"/>
                    </group>
                </group>
                <footer>
                    <button name="action_view_screen" type="object" string="Ver en pantalla" class="btn-primary"/>
                    <button name="action_print_pdf" type="object" string="Imprimir PDF"/>
                    <button name="action_export_xlsx" type="object" string="Exportar Excel"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>