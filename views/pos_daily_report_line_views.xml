<odoo>

    <record id="view_pos_daily_report_line_list" model="ir.ui.view">
        <field name="name">lms.pos.daily.report.line.list</field>
        <field name="model">lms.pos.daily.report.line</field>
        <field name="arch" type="xml">
            <list string="Reporte Ventas POS Día"
                  create="false"
                  delete="false"
                  edit="false"
                  decoration-bf="is_group or is_subtotal"
                  decoration-danger="not is_group and not is_subtotal and has_cash_counted and cash_difference &lt; 0"
                  decoration-success="not is_group and not is_subtotal and has_cash_counted and cash_difference == 0"
                  decoration-warning="not is_group and not is_subtotal and has_cash_counted and cash_difference &gt; 0">

                <field name="wizard_id" column_invisible="1"/>
                <field name="session_id" column_invisible="1"/>
                <field name="pos_config_id" column_invisible="1"/>
                <field name="cashier_id" column_invisible="1"/>
                <field name="is_group" column_invisible="1"/>
                <field name="is_subtotal" column_invisible="1"/>
                <field name="row_type" column_invisible="1"/>
                <field name="has_cash_counted" column_invisible="1"/>
                <field name="other_amount" column_invisible="1"/>
                <field name="cxc_other_amount" column_invisible="1"/>
                <field name="total_other_collected" column_invisible="1"/>

                <field name="date_label" string="Fecha / POS"/>
                <field name="session_state" string="Estado"/>
                <field name="cashier_name" string="Cajero"/>
                <field name="order_count_display" string="Cant. Órdenes POS"/>
                <field name="cxc_receipt_count_display" string="Recibos CxC"/>
                <field name="session_name" string="Sesión"/>
                <field name="session_range" string="Rango Sesión"/>

                <field name="cash_amount_display" string="Efectivo POS"/>
                <field name="cxc_cash_amount_display" string="Efectivo CxC"/>
                <field name="total_cash_collected_display" string="Total Efectivo"/>
                <field name="driver_liquidation_amount_display" string="Liq. Chofer"/>
                <field name="cash_counted_display" string="Efectivo Contado"/>
                <field name="cash_difference_display" string="Dif. Efectivo"/>

                <field name="card_amount_display" string="Tarjeta POS"/>
                <field name="cxc_card_amount_display" string="Tarjeta CxC"/>
                <field name="total_card_collected_display" string="Total Tarjeta"/>

                <field name="transfer_amount_display" string="Transferencia POS"/>
                <field name="cxc_transfer_amount_display" string="Transferencia CxC"/>
                <field name="total_transfer_collected_display" string="Total Transferencia"/>

                <field name="cxc_total_amount_display" string="Total CxC"/>
                <field name="total_sales_display" string="Total Recibido"/>

            </list>
        </field>
    </record>

</odoo>
