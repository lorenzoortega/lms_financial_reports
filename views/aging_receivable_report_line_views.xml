<odoo>

    <record id="view_aging_receivable_report_line_list" model="ir.ui.view">
        <field name="name">lms.aging.receivable.report.line.list</field>
        <field name="model">lms.aging.receivable.report.line</field>
        <field name="arch" type="xml">
            <list string="Balance por Antigüedad"
                  create="false"
                  delete="false"
                  edit="false"
                  decoration-bf="is_group"
                  decoration-info="is_subtotal">

                <field name="wizard_id" column_invisible="1"/>
                <field name="sequence" column_invisible="1"/>
                <field name="is_group" column_invisible="1"/>
                <field name="is_subtotal" column_invisible="1"/>
                <field name="partner_id" column_invisible="1"/>
                <field name="invoice_id" column_invisible="1"/>

                <field name="row_label" string="Cliente"/>
                <field name="invoice_name" string="Factura"/>
                <field name="due_date" string="Vencimiento"/>
                <field name="balance_pending" string="Balance Pendiente" sum="Total"/>
                <field name="days_overdue" string="Días Vencidos"/>
                <field name="not_due" string="No Vencida" sum="Total"/>
                <field name="bucket_1_30" string="1-30" sum="Total"/>
                <field name="bucket_31_60" string="31-60" sum="Total"/>
                <field name="bucket_61_90" string="61-90" sum="Total"/>
                <field name="bucket_90_plus" string="90+" sum="Total"/>

            </list>
        </field>
    </record>

</odoo>