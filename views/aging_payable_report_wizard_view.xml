<odoo>

    <record id="action_aging_payable_report_wizard" model="ir.actions.act_window">
        <field name="name">Balance por Antigüedad (Proveedores)</field>
        <field name="res_model">lms.aging.payable.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_aging_payable_report_wizard_form" model="ir.ui.view">
        <field name="name">lms.aging.payable.report.wizard.form</field>
        <field name="model">lms.aging.payable.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Balance por Antigüedad (Proveedores)">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>

                <footer>
                    <button name="action_view_screen"
                            string="Ver en Pantalla"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_print_pdf"
                            string="Generar PDF"
                            type="object"
                            class="btn-secondary"/>

                    <button name="action_export_xlsx"
                            string="Exportar Excel"
                            type="object"
                            class="btn-secondary"/>

                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>