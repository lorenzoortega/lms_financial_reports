<odoo>

    <!-- Vista del wizard -->
    <record id="view_income_statement_wizard_form" model="ir.ui.view">
        <field name="name">income.statement.wizard.form</field>
        <field name="model">lms.income.statement.wizard</field>
        <field name="arch" type="xml">

            <form string="Estado de Resultados">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>

                <footer>

                    <button name="action_view_screen"
                            string="Generar"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_print_pdf"
                            string="Generar PDF"
                            type="object"
                            class="btn-secondary"/>

                    <button name="action_export_xlsx"
                            string="Exportar Excel"
                            type="object"
                            class="btn-secondary"/>

                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>

                </footer>
            </form>

        </field>
    </record>

    <!-- Acción -->
    <record id="action_income_statement_wizard" model="ir.actions.act_window">
        <field name="name">Estado de Resultados</field>
        <field name="res_model">lms.income.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>